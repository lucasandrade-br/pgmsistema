# EDITORES / IDEs
# ──────────────────────────────────────────────────────────────────────────────

.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace
!.vscode/extensions.json

.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

